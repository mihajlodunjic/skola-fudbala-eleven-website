---
import { business, externalLabels } from "@data/business";
import { copy } from "@data/copy";
import { navigation } from "@data/navigation";

const year = new Date().getFullYear();
const navItems = navigation.map((item) => ({
  ...item,
  disabled: item.href !== "/"
}));
---

<footer class="site-footer">
  <div class="site-footer__inner container">
    <div class="footer-brand">
      <a href="/" aria-label="Škola fudbala ELEVEN - početna">
        <img
          src={business.logo.src}
          width={business.logo.width}
          height={business.logo.height}
          alt={business.footerLogoAlt}
          loading="lazy"
          decoding="async"
        />
      </a>
      <p>{copy.footer.description}</p>
      <strong>{business.slogan}</strong>
    </div>

    <nav class="footer-nav" aria-label={copy.footer.pages}>
      <h2>{copy.footer.pages}</h2>
      {navItems.map((item) => (
        <a
          href={item.disabled ? undefined : item.href}
          aria-disabled={item.disabled ? "true" : undefined}
          data-disabled-link={item.disabled ? "true" : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <address class="footer-contact">
      <h2>{copy.footer.contact}</h2>
      <a aria-label={externalLabels.phone} aria-disabled="true" data-disabled-link="true">{business.phoneDisplay}</a>
      <a aria-label={externalLabels.email} aria-disabled="true" data-disabled-link="true">{business.email}</a>
      <h2>{copy.footer.field}</h2>
      <a aria-label={externalLabels.map} aria-disabled="true" data-disabled-link="true">
        {business.address.display}
      </a>
    </address>

    <div class="footer-social">
      <h2>{copy.footer.social}</h2>
      <a aria-label={externalLabels.instagram} aria-disabled="true" data-disabled-link="true">
        {business.instagram.username}
      </a>
      <a class="footer-top" href="#top">{copy.footer.backTop}</a>
    </div>

    <p class="footer-line">© {year} {business.name}.</p>
  </div>
</footer>
