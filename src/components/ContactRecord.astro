---
interface ContactItem {
  label: string;
  value: string;
  href: string;
  action: string;
  ariaLabel?: string;
  external?: boolean;
  disabled?: boolean;
}

interface Props {
  items: ContactItem[];
  heading?: string;
}

const { items, heading } = Astro.props;
---

<dl class="contact-record" aria-label={heading}>
  {items.map((item) => (
    <div class="contact-record__item">
      <dt>{item.label}</dt>
      <dd>
        <a
          href={item.disabled ? undefined : item.href}
          aria-label={item.ariaLabel}
          aria-disabled={item.disabled ? "true" : undefined}
          data-disabled-link={item.disabled ? "true" : undefined}
          target={item.external && !item.disabled ? "_blank" : undefined}
          rel={item.external && !item.disabled ? "noopener noreferrer" : undefined}
        >
          {item.value}
          {item.external && !item.disabled && <span class="sr-only">Otvara se u novoj kartici</span>}
        </a>
      </dd>
      <a
        class="contact-record__action"
        href={item.disabled ? undefined : item.href}
        aria-label={item.ariaLabel}
        aria-disabled={item.disabled ? "true" : undefined}
        data-disabled-link={item.disabled ? "true" : undefined}
        target={item.external && !item.disabled ? "_blank" : undefined}
        rel={item.external && !item.disabled ? "noopener noreferrer" : undefined}
      >
        {item.action}
        {item.external && !item.disabled && <span class="sr-only">Otvara se u novoj kartici</span>}
      </a>
    </div>
  ))}
</dl>
